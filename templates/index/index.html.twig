{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<main>
    <section class="section-image section-full-width-right light ken-burn-center" data-parallax="scroll" data-image-src="{{ asset('assets/img/chalets/chalet_chalaronne.jpg') }}">
        <div class="container">
            <hr class="space-lg"/>
            <hr class="space-sm"/>
            <div class="row">
                <div class="col-lg-6">
                    <h1 data-anima="fade-left" data-time="2000" class="text-lg text-uppercase text-black">Camping de la chalaronne</h1>
                    <hr class="space-lg"/>
                    <hr class="space-sm hidden-lg" />
                </div>
                <div class="col-lg-6">
                    <hr class="space-xs" />
                    <div class="counter counter-vertical counter-icon">
                        <div>
                            <h3>Superficie</h3>
                            <div class="value">
                                <span class="text-md" data-to="6" data-speed="1500">6</span>
                                <span>hectares</span>
                            </div>
                        </div>
                    </div>
                    <hr class="space-sm" />
                    <div class="counter counter-vertical counter-icon">
                        <div>
                            <h3>Chalets</h3>
                            <div class="value">
                                <span class="text-md" data-to="12" data-speed="1500">12</span>
                                <span>chalets</span>
                            </div>
                        </div>
                    </div>
                    <hr class="space-sm" />
                    <div class="counter counter-vertical counter-icon">
                        <div>
                            <h3>Emplacements</h3>
                            <div class="value">
                                <span class="text-md" data-to="120" data-speed="1500">120</span>
                                <span>emplacements</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="space-lg" />
        </div>
    </section>

    <section class="section-base">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <ul class="slider controls-right" data-options="type:carousel,nav:true,perView:2,perViewSm:1,gap:30,controls:out">
                        <li>
                            <div class="cnt-box cnt-box-info" data-href="{{path('app_prestation')}}">
                                <div class="extra-field">À partir de 55€</div>
                                <a href="{{path('app_prestation')}}" class="img-box">
                                    <img src="{{ asset('assets/img/chalets/chalets.jpg') }}" alt="Chalets du Camping de la Chalaronne, séjour en pleine nature" />
                                </a>
                                <div class="caption">
                                    <h2>Nos chalets</h2>
                                    <div class="cnt-info">
                                        <div><span>Séjour</span><span>Nuit</span></div>
                                        <div><span>Capacité</span><span>6</span></div>
                                        <div><span>Confort</span><span>✓</span></div>
                                    </div>
                                    <p>Des chalets chaleureux pour profiter de la nature sans renoncer au bien-être.</p>
                                </div>
                            </div>
                        </li>
                        <li>
                            <div class="cnt-box cnt-box-info" data-href="{{path('app_prestation')}}">
                                <div class="extra-field">À partir de 10€</div>
                                <a href="{{path('app_prestation')}}" class="img-box">
                                    <img src="{{ asset('assets/img/emplacement/emplacement.jpg') }}" alt="Emplacements pour tentes, vans et camping-cars au Camping de la Chalaronne" />
                                </a>
                                <div class="caption">
                                    <h2>Nos emplacements</h2>
                                    <div class="cnt-info">
                                        <div><span>Nuit</span><span>1</span></div>
                                        <div><span>Sanitaire</span><span>✓</span></div>
                                        <div><span>Nature</span><span>100%</span></div>
                                    </div>
                                    <p>Installez votre tente, van ou camping-car au bord de l’eau et savourez la simplicité du plein air.</p>
                                </div>
                            </div>
                        </li>
                        <li>
                            <div class="cnt-box cnt-box-info" data-href="{{path('app_prestation')}}">
                                <div class="extra-field">À partir de 116€</div>
                                <a href="{{path('app_prestation')}}" class="img-box">
                                    <img src="{{ asset('assets/img/emplacement/emplacement_resident.jpg') }}" alt="Emplacement résident du Camping de la Chalaronne, au bord de la rivière" />
                                </a>
                                <div class="caption">
                                    <h2>Emplacement résident</h2>
                                    <div class="cnt-info">
                                        <div><span>Mois</span><span>1</span></div>
                                        <div><span>Bord rivière</span><span>✓</span></div>
                                        <div><span>Convivial</span><span>✓</span></div>
                                    </div>
                                    <p>Des chalets chaleureux, parfaits pour une halte reposante ou un séjour prolongé à la découverte de la région.</p>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <hr class="space-sm visible-sm" />
                    <div class="title">
                        <h2>Nos prestations</h2>
                        <p>Découvrez un séjour au vert</p>
                    </div>
                    <p>Le Camping de la Chalaronne est un havre de paix au bord de l’eau, idéal pour se ressourcer et partager de beaux moments en plein air.</p>
                    <a href="{{path('app_prestation')}}" class="btn btn-circle btn-xs">En savoir plus</a>
                </div>
            </div>
        </div>
    </section>

    <section class="section-base">
        <div class="container">
            <div class="title align-center">
                <h2>Nos services & activités</h2>
                <p>Profitez pleinement de votre séjour à la Chalaronne</p>
            </div>
            <table class="table table-grid table-border table-6-md">
                <tbody>
                    <tr>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-golf"></i>
                                <div class="caption">
                                    <h3>Mini-golf</h3>
                                    <p>Un espace ludique pour partager un moment convivial en famille ou entre amis.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-water"></i>
                                <div class="caption">
                                    <h3>Bord de rivière</h3>
                                    <p>Un cadre paisible au bord de la Chalaronne pour se détendre et se ressourcer.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-bicycle"></i>
                                <div class="caption">
                                    <h3>Balades & vélo</h3>
                                    <p>De nombreux chemins et itinéraires pour découvrir la région en douceur.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-home-2"></i>
                                <div class="caption">
                                    <h3>Chalets chaleureux</h3>
                                    <p>Des hébergements équipés pour une halte ou un séjour prolongé.</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-paw"></i>
                                <div class="caption">
                                    <h3>Touroparc Zoo</h3>
                                    <p>À quelques minutes du camping, découvrez les animaux et attractions de Touroparc Zoo.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-glass"></i>
                                <div class="caption">
                                    <h3>Hameau Dubœuf</h3>
                                    <p>Explorez l’univers de la vigne au Hameau Dubœuf, un musée unique en son genre.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-map2"></i>
                                <div class="caption">
                                    <h3>Découverte du Beaujolais</h3>
                                    <p>Villages de caractère, vignobles et gastronomie à quelques minutes du camping.</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="icon-box icon-box-top align-center">
                                <i class="im-sun"></i>
                                <div class="caption">
                                    <h3>Esprit convivial</h3>
                                    <p>Une ambiance familiale et chaleureuse pour des vacances simples et authentiques.</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</main>
{% endblock %}