                {% set counters = [
                    {'title':'Medium altitude','value':1800,'unit':'mm'},
                    {'title':'Yearly visitors','value':8000,'unit':'+'},
                    {'title':'Refuges','value':18,'unit':'+'},
                    {'title':'Area size','value':6000,'unit':'mq'}
                ] %}
                {% for counter in counters %}
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="counter counter-vertical counter-icon">
                            <div>
                                <h3>{{ counter.title }}</h3>
                                <div class="value">
                                    <span class="text-lg" data-to="{{ counter.value }}" data-speed="5000">{{ counter.value }}</span>
                                    <span>{{ counter.unit }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
