<main>

    {# Hero Section avec image de fond et texte #}
    <section class="section-image section-full-width-right light ken-burn-center" data-parallax="scroll" data-image-src="media/hd-10.jpg">
        <div class="container text-center" style="padding-top: 70vh;">
            <h1>Nos prestations</h1>
            <h3>Travel to see what a tiny place you occupy in the world</h3>
        </div>
    </section>
    <section>
        {# Slider des services #}
        <div class="container">
            <ul class="slider" data-options="type:carousel,arrows:true,controls:out,perView:4,perViewMd:3,perViewSm:2,perViewXs:1,gap:30">
                {% set services = [
                    {'icon':'fa-solid fa-cloud-sun','title':'Views','text':'Enjoy amazing and unique natural views.'},
                    {'icon':'fa-solid fa-mug-hot','title':'Breakfast','text':'Take a break in our refuges and huts.'},
                    {'icon':'fa-solid fa-shoe-prints','title':'Trekking','text':'Lots of refuges through the paths and treks.'},
                    {'icon':'fa-solid fa-person-hiking','title':'Cable car','text':'Try the many panoramic cable cars.'}
                ] %}
                {% for service in services %}
                    <li>
                        <div class="cnt-box cnt-box-top-icon boxed">
                            <i class="{{ service.icon }}"></i>
                            <div class="caption">
                                <h2>{{ service.title }}</h2>
                                <p>{{ service.text }}</p>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </section>

